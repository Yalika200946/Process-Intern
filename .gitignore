# Data (large files - add your data separately)
data/
*.csv
*.xlsx
*.xls

# ── Plant data protection (prevent pushing REAL tags/values to a public repo) ──
# Real computed dashboard results contain real instrument tags + operating values.
# They stay LOCAL (dashboard still works on your machine) but are never committed.
# Publish the anonymized  demo/  folder instead (safe, fake data).
dashboard/data/*.json
backend/uploads/
**/uploads/
**/backup_*/
Data/
# demo/ (anonymized) is intentionally NOT ignored — it is the safe, publishable artifact

# Windows reserved-device-name junk files (accidental `> nul` redirects; block git add on Windows)
notebooks/_archive_2026-07-12/nul
notebooks/_archive_2026-07-12/root_nul

# Canonical pipeline runtime outputs
logs/
reports/figures/
reports/tables/
reports/executed_notebooks/
models/*
!models/.gitkeep
data/raw/
data/interim/
data/processed/
data/features/
data/gold/
.env
